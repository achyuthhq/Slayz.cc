# Discord OAuth Integration
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:3000/callback/discord

# Client-side Discord variables (must match server variables)
NEXT_PUBLIC_DISCORD_CLIENT_ID=your_discord_client_id
NEXT_PUBLIC_DISCORD_REDIRECT_URI=http://localhost:3000/callback/discord

# Other environment variables for your application
# DATABASE_URL=
# API_KEY=
# etc.

# Resend API for emails - REQUIRED for password reset functionality
# Sign up at https://resend.com to get an API key
RESEND_API_KEY=re_example_your_resend_api_key

# Custom email sender address (optional)
# If not provided, will use the Resend test address 'onboarding@resend.dev'
# For production, you should verify your domain in Resend and use your own address
EMAIL_FROM=your-verified-email@yourdomain.com

# NODE_ENV=development (enables debug info for password resets)
NODE_ENV=development

# Steam Integration
STEAM_API_KEY=YOUR_STEAM_API_KEY 